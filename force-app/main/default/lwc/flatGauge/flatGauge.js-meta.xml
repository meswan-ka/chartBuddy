<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage,lightning__AppPage">
            <property name="chartTitle" type="String" label="Chart Title" />
            <property name="query" type="String" label="SOQL Query" description="Single-value aggregate query. Use :recordId for context binding." />
            <property name="maxValue" type="Integer" label="Max Value" default="100" />
            <property name="referenceValue" type="Integer" label="Reference Value" description="Optional reference line position" />
            <property name="referenceLabel" type="String" label="Reference Label" default="Avg" />
            <property name="valuePrefix" type="String" label="Value Prefix" />
            <property name="valueSuffix" type="String" label="Value Suffix" description="e.g. M, %, K" />
            <property name="gradientStops" type="String" label="Gradient Colors" description="Comma-separated hex colors for fill gradient, e.g. #2E844A,#FFB03B,#C23934" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
