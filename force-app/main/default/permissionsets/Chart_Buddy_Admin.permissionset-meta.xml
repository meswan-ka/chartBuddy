<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Chart Buddy Admin</label>
    <description>Full access to Chart Buddy components, configuration object, and Apex controllers.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <objectPermissions>
        <object>Chart_Buddy_Config__c</object>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>Chart_Buddy_Config__c.Config_JSON__c</field>
        <editable>true</editable>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Chart_Buddy_Config__c.Description__c</field>
        <editable>true</editable>
        <readable>true</readable>
    </fieldPermissions>
    <classAccesses>
        <apexClass>ChartQueryController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ChartBuddyConfigController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ChartBuddyConfigPicklist</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <tabSettings>
        <tab>Chart_Buddy_Configurator</tab>
        <visibility>Visible</visibility>
    </tabSettings>
</PermissionSet>
